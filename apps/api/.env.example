# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://shodumo:shodumo@localhost:5432/shodumo?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_FEED_TTL=60

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_TTL=7d

# Throttler
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# Media (stub for Cloudflare R2 / S3)
MEDIA_PUBLIC_BASE_URL=http://localhost:3000/static
