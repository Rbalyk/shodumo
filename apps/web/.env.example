# Base URL of the ShoDumo REST API (NestJS backend).
# Single source of the API address for `gulp build`, `gulp prerender` and the
# runtime client bundle. localhost is the local-dev default only — set this to
# the public API origin in prod (e.g. https://api.shodumo.com).
API_URL=http://localhost:3000

# Public canonical origin of this site (used for canonical URLs, OG, sitemap)
SITE_URL=http://localhost:3001

# Default city for ЧПУ routes
DEFAULT_CITY=lviv

# Dev server port (BrowserSync)
DEV_PORT=3001
