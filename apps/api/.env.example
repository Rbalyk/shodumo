# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://shodumo:shodumo@localhost:5432/shodumo?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_FEED_TTL=60

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_TTL=7d

# Throttler
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# Auth cookies + SSO
# Origins allowed to send credentialed requests (comma-separated, no spaces).
# Must be exact origins, never "*", because credentials are enabled.
CORS_ORIGINS=http://localhost:3001,http://localhost:4200
# Parent domain the auth cookies are scoped to, enabling SSO across subdomains
# (e.g. .shodumo.com). Leave empty in dev for host-only localhost cookies.
COOKIE_DOMAIN=
# Public origin of this API — used to build the email confirmation link.
API_PUBLIC_URL=http://localhost:3000
# Public site origin — where /auth/confirm redirects after creating the user.
WEB_BASE_URL=http://localhost:3001

# Email (Resend). Without RESEND_API_KEY the confirmation link is logged
# instead of sent (local dev).
RESEND_API_KEY=
MAIL_FROM=ShoDumo <noreply@shodumo.com>

# Media (stub for Cloudflare R2 / S3)
MEDIA_PUBLIC_BASE_URL=http://localhost:3000/static
