# ShoDumo — продакшн-секрети. Скопіюй у .env.prod і заповни. У git НЕ комітити!

# --- Postgres ---
POSTGRES_USER=shodumo
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=shodumo

# --- Redis ---
REDIS_PASSWORD=change_me_redis_password

# --- JWT ---
# згенеруй: openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret

# --- CORS (домени фронтів) ---
# єдиний фронт-origin (публічний сайт + кабінет + адмінка в одному Angular-застосунку)
CORS_ORIGINS=https://shodumo.com

# --- Cookies ---
# спільний батьківський домен → cookie shodumo.com доступні і для api.shodumo.com
# (порожнє значення лише для локальної розробки)
COOKIE_DOMAIN=.shodumo.com

# --- Auth flow URLs ---
# публічний базовий URL API — у лист підтвердження вшивається ${API_PUBLIC_URL}/auth/confirm
API_PUBLIC_URL=https://api.shodumo.com
# куди редіректить /auth/confirm після успіху (публічний сайт = єдиний фронт)
WEB_BASE_URL=https://shodumo.com

# --- Web (Angular SSR) ---
# хости, для яких SSR-движок рендерить (localhost додається автоматично для health-check)
WEB_ALLOWED_HOSTS=shodumo.com

# --- Email (Resend) ---
# ключ із resend.com → API Keys; якщо порожній — лінк лише логуватиметься (dev)
RESEND_API_KEY=
MAIL_FROM=ShoDumo <noreply@shodumo.com>

# --- Cloudflare Tunnel ---
# токен із Zero Trust → Networks → Tunnels → (твій тунель)
CLOUDFLARE_TUNNEL_TOKEN=

# --- R2 (S3-сумісне сховище медіа) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=shodumo-media
